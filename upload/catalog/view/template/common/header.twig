<!DOCTYPE html>
<html dir="{{ direction }}" lang="{{ lang }}">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>{{ title }}</title>
  <base href="{{ base }}"/>
  {% if description %}
    <meta name="description" content="{{ description }}"/>
  {% endif %}
  {% if keywords %}
    <meta name="keywords" content="{{ keywords }}"/>
  {% endif %}
  <script src="{{ jquery }}" type="text/javascript"></script>
  <link href="{{ bootstrap }}" type="text/css" rel="stylesheet" media="screen"/>
  <link href="{{ icons }}" rel="stylesheet" type="text/css"/>
  <link href="{{ stylesheet }}" type="text/css" rel="stylesheet"/>
  <script src="catalog/view/javascript/common.js" type="text/javascript"></script>
  {% if icon %}
    <link rel="icon" href="{{ icon }}" type="image/png" sizes="32x32">
    <link rel="apple-touch-icon" href="{{ icon_apple }}">
    <link rel="icon" href="{{ icon_192 }}" type="image/png" sizes="192x192">
  {% endif %}
  {% for style in styles %}
    <link href="{{ style.href }}" type="text/css" rel="{{ style.rel }}" media="{{ style.media }}"/>
  {% endfor %}
  {% for script in scripts %}
    <script src="{{ script.href }}" type="text/javascript"></script>
  {% endfor %}
  {% for link in links %}
    <link href="{{ link.href }}" rel="{{ link.rel }}"/>
  {% endfor %}
  {% for analytic in analytics %}
    {{ analytic }}
  {% endfor %}
</head>
<body class="theme-miigtools">
<div id="container">
  <div id="alert"></div>
  {# Barra utilitária: sem repetir carrinho/checkout (ficam no header). Ícones + rótulos curtos onde faz sentido. #}
  <nav id="top" class="miig-topbar" aria-label="Utilitários da loja">
    <div class="container">
      <div class="miig-topbar-inner">
        <div class="miig-topbar-start">
          <span class="miig-topbar-tagline d-none d-lg-inline"><i class="fa-solid fa-truck-fast" aria-hidden="true"></i> Envio em todo o Brasil</span>
          <div class="miig-topbar-locale d-flex align-items-center gap-2">
            {{ currency }}{{ language }}
          </div>
        </div>
        <div class="miig-topbar-actions">
          {% if telephone %}
            <a href="tel:{{ telephone|replace({' ': '', '-': '', '(': '', ')': '', '.': ''}) }}" class="miig-icon-btn miig-icon-btn--ghost" title="Ligar: {{ telephone }}" aria-label="Telefone {{ telephone }}"><i class="fa-solid fa-phone" aria-hidden="true"></i></a>
          {% endif %}
          <div class="dropdown miig-account-dd">
            <button type="button" class="miig-icon-btn miig-icon-btn--ghost dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" aria-label="{{ text_account }}" id="miig-account-menu">
              <i class="fa-solid fa-user" aria-hidden="true"></i>
              <span class="miig-icon-btn-label d-none d-xl-inline">{{ text_account }}</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="miig-account-menu">
              {% if not logged %}
                <li><a href="{{ register }}" class="dropdown-item">{{ text_register }}</a></li>
                <li><a href="{{ login }}" class="dropdown-item">{{ text_login }}</a></li>
              {% else %}
                <li><a href="{{ account }}" class="dropdown-item">{{ text_account }}</a></li>
                <li><a href="{{ order }}" class="dropdown-item">{{ text_order }}</a></li>
                <li><a href="{{ transaction }}" class="dropdown-item">{{ text_transaction }}</a></li>
                <li><a href="{{ download }}" class="dropdown-item">{{ text_download }}</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a href="{{ logout }}" class="dropdown-item">{{ text_logout }}</a></li>
              {% endif %}
            </ul>
          </div>
          <a href="{{ wishlist }}" id="wishlist-total" class="miig-icon-btn miig-icon-btn--ghost position-relative" title="{{ text_wishlist }}" aria-label="{{ text_wishlist }}">
            <i class="fa-solid fa-heart" aria-hidden="true"></i>
            {% if wishlist_count > 0 %}<span class="miig-icon-badge">{{ wishlist_count }}</span>{% endif %}
          </a>
        </div>
      </div>
    </div>
  </nav>
  <header class="miig-main-header">
    <div class="container">
      <div class="row align-items-center g-3">
        <div class="col-md-3 col-lg-4">
          <div id="logo">
            {% if logo %}
              <a href="{{ home }}"><img src="{{ logo }}" title="{{ name }}" alt="{{ name }}" class="miig-logo-img"/></a>
            {% else %}
              <h1 class="h4 mb-0"><a href="{{ home }}">{{ name }}</a></h1>
            {% endif %}
          </div>
        </div>
        <div class="col-md-5">{{ search }}</div>
        <div id="cart" class="col-md-4 col-lg-3 mb-0">{{ cart }}</div>
      </div>
    </div>
  </header>
  <main>
    {{ menu }}
