<section class="miig-section miig-section--products" aria-labelledby="miig-bestseller-heading">
  <header class="miig-section-head text-center text-md-start">
    <h2 id="miig-bestseller-heading" class="miig-section-title">{{ heading_title }}</h2>
  </header>
  <div class="row{% if axis == 'horizontal' %} row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4{% endif %} g-3 g-md-4">
  {% for product in products %}
    <div class="col">{{ product }}</div>
  {% endfor %}
  </div>
</section>
