{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-payment" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-pencil"></i> {{ text_edit }}</div>
      <div class="card-body">
        <form id="form-payment" action="{{ save }}" method="post" data-oc-toggle="ajax">
          <div class="row mb-3">
            <label for="input-environment" class="col-sm-2 col-form-label">{{ entry_environment }}</label>
            <div class="col-sm-10">
              <select name="payment_mercadopago_environment" id="input-environment" class="form-select">
                <option value="sandbox"{% if payment_mercadopago_environment == 'sandbox' %} selected{% endif %}>{{ text_sandbox }}</option>
                <option value="production"{% if payment_mercadopago_environment == 'production' %} selected{% endif %}>{{ text_production }}</option>
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-public-key-test" class="col-sm-2 col-form-label">{{ entry_public_key_test }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_mercadopago_public_key_test" value="{{ payment_mercadopago_public_key_test }}" id="input-public-key-test" class="form-control"/>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-access-token-test" class="col-sm-2 col-form-label">{{ entry_access_token_test }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_mercadopago_access_token_test" value="{{ payment_mercadopago_access_token_test }}" id="input-access-token-test" class="form-control"/>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-public-key" class="col-sm-2 col-form-label">{{ entry_public_key }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_mercadopago_public_key" value="{{ payment_mercadopago_public_key }}" id="input-public-key" class="form-control"/>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-access-token" class="col-sm-2 col-form-label">{{ entry_access_token }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_mercadopago_access_token" value="{{ payment_mercadopago_access_token }}" id="input-access-token" class="form-control"/>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-order-status-pending" class="col-sm-2 col-form-label">{{ entry_order_status_pending }}</label>
            <div class="col-sm-10">
              <select name="payment_mercadopago_order_status_pending" id="input-order-status-pending" class="form-select">
                {% for order_status in order_statuses %}
                  <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_mercadopago_order_status_pending %} selected{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-order-status-approved" class="col-sm-2 col-form-label">{{ entry_order_status_approved }}</label>
            <div class="col-sm-10">
              <select name="payment_mercadopago_order_status_approved" id="input-order-status-approved" class="form-select">
                {% for order_status in order_statuses %}
                  <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_mercadopago_order_status_approved %} selected{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-order-status-rejected" class="col-sm-2 col-form-label">{{ entry_order_status_rejected }}</label>
            <div class="col-sm-10">
              <select name="payment_mercadopago_order_status_rejected" id="input-order-status-rejected" class="form-select">
                {% for order_status in order_statuses %}
                  <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_mercadopago_order_status_rejected %} selected{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-order-status-refunded" class="col-sm-2 col-form-label">{{ entry_order_status_refunded }}</label>
            <div class="col-sm-10">
              <select name="payment_mercadopago_order_status_refunded" id="input-order-status-refunded" class="form-select">
                {% for order_status in order_statuses %}
                  <option value="{{ order_status.order_status_id }}"{% if order_status.order_status_id == payment_mercadopago_order_status_refunded %} selected{% endif %}>{{ order_status.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-geo-zone" class="col-sm-2 col-form-label">{{ entry_geo_zone }}</label>
            <div class="col-sm-10">
              <select name="payment_mercadopago_geo_zone_id" id="input-geo-zone" class="form-select">
                <option value="0">{{ text_all_zones }}</option>
                {% for geo_zone in geo_zones %}
                  <option value="{{ geo_zone.geo_zone_id }}"{% if geo_zone.geo_zone_id == payment_mercadopago_geo_zone_id %} selected{% endif %}>{{ geo_zone.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ entry_status }}</label>
            <div class="col-sm-10">
              <div class="form-check form-switch form-switch-lg">
                <input type="hidden" name="payment_mercadopago_status" value="0"/>
                <input type="checkbox" name="payment_mercadopago_status" value="1" id="input-status" class="form-check-input"{% if payment_mercadopago_status %} checked{% endif %}/>
              </div>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-sort-order" class="col-sm-2 col-form-label">{{ entry_sort_order }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_mercadopago_sort_order" value="{{ payment_mercadopago_sort_order }}" id="input-sort-order" class="form-control"/>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}
