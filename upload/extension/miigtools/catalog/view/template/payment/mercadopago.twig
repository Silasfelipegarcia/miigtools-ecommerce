<div id="mercadopago-payment">
  {% if public_key and amount > 0 %}
    <div id="paymentBrick_container"></div>
    <div id="mercadopago-pix-panel" class="d-none mt-3">
      <h5>{{ text_pix_title }}</h5>
      <div class="text-center mb-3"><img id="mercadopago-pix-qr" src="" alt="Pix QR Code" class="img-fluid" style="max-width: 260px;"/></div>
      <div class="input-group mb-2">
        <input type="text" id="mercadopago-pix-code" class="form-control" readonly/>
        <button type="button" id="mercadopago-pix-copy" class="btn btn-outline-secondary">{{ text_pix_copy }}</button>
      </div>
      <p class="text-muted mb-0">{{ text_pix_waiting }}</p>
    </div>
  {% else %}
    <div class="alert alert-warning mb-0">{{ error_credentials }}</div>
  {% endif %}
</div>
<script src="https://sdk.mercadopago.com/js/v2"></script>
<script type="text/javascript"><!--
(function() {
    const publicKey = '{{ public_key|e('js') }}';
    const amount = {{ amount }};
    const processUrl = '{{ process_url|e('js') }}';
    const statusUrl = '{{ status_url|e('js') }}';
    const successUrl = '{{ success_url|e('js') }}';
    let pollTimer = null;

    function showAlert(message, type) {
        $('#alert').prepend('<div class="alert alert-' + type + ' alert-dismissible"><i class="fa-solid fa-circle-exclamation"></i> ' + message + ' <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
    }

    function startPixPolling(paymentId) {
        if (pollTimer) {
            clearInterval(pollTimer);
        }

        pollTimer = setInterval(function() {
            $.ajax({
                url: statusUrl + '&payment_id=' + paymentId,
                dataType: 'json',
                success: function(json) {
                    if (json.redirect) {
                        clearInterval(pollTimer);
                        location = json.redirect;
                    }
                }
            });
        }, 5000);
    }

    if (!publicKey || amount <= 0) {
        return;
    }

    const mp = new MercadoPago(publicKey, { locale: 'pt-BR' });
    const bricksBuilder = mp.bricks();

    bricksBuilder.create('payment', 'paymentBrick_container', {
        initialization: {
            amount: amount
        },
        customization: {
            paymentMethods: {
                creditCard: 'all',
                debitCard: 'all',
                bankTransfer: 'all'
            }
        },
        callbacks: {
            onReady: function() {
                $('#button-confirm').hide();
            },
            onSubmit: function({ formData }) {
                return new Promise(function(resolve, reject) {
                    $.ajax({
                        url: processUrl,
                        method: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify(formData),
                        dataType: 'json',
                        beforeSend: function() {
                            $('#paymentBrick_container').addClass('opacity-50');
                        },
                        complete: function() {
                            $('#paymentBrick_container').removeClass('opacity-50');
                        },
                        success: function(json) {
                            if (json.error) {
                                showAlert(json.error, 'danger');
                                reject();
                                return;
                            }

                            if (json.redirect) {
                                location = json.redirect;
                                resolve();
                                return;
                            }

                            if (json.pix) {
                                $('#paymentBrick_container').hide();
                                $('#mercadopago-pix-panel').removeClass('d-none');

                                if (json.pix.qr_code_base64) {
                                    $('#mercadopago-pix-qr').attr('src', 'data:image/png;base64,' + json.pix.qr_code_base64);
                                }

                                $('#mercadopago-pix-code').val(json.pix.qr_code || '');
                                startPixPolling(json.payment_id);
                                resolve();
                                return;
                            }

                            resolve();
                        },
                        error: function() {
                            showAlert('{{ error_payment|e('js') }}', 'danger');
                            reject();
                        }
                    });
                });
            },
            onError: function(error) {
                console.error(error);
            }
        }
    });

    $('#mercadopago-pix-copy').on('click', function() {
        const code = $('#mercadopago-pix-code').val();

        if (navigator.clipboard) {
            navigator.clipboard.writeText(code);
        }
    });
})();
//--></script>
