# Railway injeta MYSQLHOST, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE, MYSQLPORT automaticamente
# ao adicionar o plugin MySQL e referenciar no serviço web.

# Opcional — só defina se quiser sobrescrever o que o MySQL do Railway fornece:
# DB_HOSTNAME=
# DB_USERNAME=
# DB_PASSWORD=
# DB_DATABASE=
# DB_PORT=3306

# Prefixo das tabelas (local e produção MIIGTOOLS)
DB_PREFIX=ws_

# URL pública (Railway preenche RAILWAY_PUBLIC_DOMAIN automaticamente)
OPENCART_HTTP_SCHEME=https
# OPENCART_HTTP_HOST=miigtools.up.railway.app
